{
  "name": "bare-wifi-android",
  "version": "0.1.4",
  "description": "Android WifiManager bindings for the Bare runtime — multicast lock and WiFi interface IP",
  "exports": {
    "./package": "./package.json",
    ".": "./index.js"
  },
  "files": [
    "index.js",
    "binding.cc",
    "binding.js",
    "CMakeLists.txt",
    "prebuilds"
  ],
  "addon": true,
  "scripts": {
    "format": "prettier --write .",
    "lint": "prettier --check . && lunte",
    "test": "brittle-bare --coverage test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holepunchto/bare-wifi-android.git"
  },
  "author": "Holepunch",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/holepunchto/bare-wifi-android/issues"
  },
  "homepage": "https://github.com/holepunchto/bare-wifi-android#readme",
  "devDependencies": {
    "brittle": "^3.4.0",
    "cmake-android": "^0.1.4",
    "cmake-bare": "^1.8.0",
    "cmake-fetch": "^1.5.1",
    "cmake-java": "^0.1.2",
    "lunte": "^1.3.0",
    "prettier": "^3.3.3",
    "prettier-config-holepunch": "^2.0.0"
  }
}
